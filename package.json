{
  "name": "ccdoc",
  "private": true,
  "version": "0.1.1",
  "description": "Desktop documentation app for software projects",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "cd packages/core && npx tsup && cd ../mcp-server && npx tsup && cd ../desktop && npx electron-vite build",
    "build:core": "cd packages/core && npx tsup",
    "build:mcp": "cd packages/mcp-server && npx tsup",
    "build:desktop": "cd packages/desktop && npx electron-vite build",
    "package": "cd packages/desktop && npx electron-builder --publish never",
    "package:win": "cd packages/desktop && npx electron-builder --win --publish never",
    "package:mac": "cd packages/desktop && npx electron-builder --mac --publish never",
    "package:linux": "cd packages/desktop && npx electron-builder --linux --publish never",
    "release": "bash scripts/release.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "tree-sitter",
      "tree-sitter-typescript",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-rust",
      "tree-sitter-go",
      "onnxruntime-node",
      "protobufjs",
      "libsql",
      "electron",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
